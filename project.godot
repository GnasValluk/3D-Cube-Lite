; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CUPY Cozy Daily"
run/main_scene="res://scenes/start_menu.tscn"
config/features=PackedStringArray("4.7", "Mobile")
boot_splash/bg_color=Color(0.06, 0.06, 0.1, 1)
config/icon="res://icon.svg"

[autoload]

WorldSeed="*res://scripts/core/world_seed.gd"
TimeSystem="*res://scripts/core/time_system.gd"
SFXManager="*res://scripts/audio/sfx_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
